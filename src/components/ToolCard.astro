---
interface Props {
  name: string;
  slug: string;
  description: string;
  summary?: string;
  website?: string;
  rating: number;
  pros?: string[];
  cons?: string[];
  affiliate_url?: string;
}

const { name, slug, description, summary, website, rating, pros = [], cons = [], affiliate_url } = Astro.props;

const ratingPercent = (rating / 5) * 100;
const faviconUrl = website ? `https://www.google.com/s2/favicons?domain=${website}&sz=64` : '';
const initial = name.charAt(0).toUpperCase();
---

<article class="tool-card">
  <div class="card-header">
    <div class="card-identity">
      <div class="card-logo">
        {website ? (
          <img src={faviconUrl} alt={`${name} logo`} width="32" height="32" loading="lazy" />
        ) : (
          <div class="logo-fallback">{initial}</div>
        )}
      </div>
      <div>
        <h3 class="card-title">
          <a href={`/${slug}`}>{name}</a>
        </h3>
        <div class="card-rating">
          <div class="rating-bar" title={`${rating} out of 5`}>
            <div class="rating-bar-fill" style={`width: ${ratingPercent}%`}></div>
          </div>
          <span class="rating-num">{rating}/5</span>
        </div>
      </div>
    </div>
  </div>

  <p class="card-desc">{description}</p>

  {summary && (
    <div class="card-summary">
      <span class="summary-label">Why choose this?</span>
      {summary}
    </div>
  )}

  {(pros.length > 0 || cons.length > 0) && (
    <div class="card-pros-cons">
      {pros.length > 0 && (
        <div class="pros">
          <span class="label label-pro">Pros</span>
          <ul>
            {pros.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      )}
      {cons.length > 0 && (
        <div class="cons">
          <span class="label label-con">Cons</span>
          <ul>
            {cons.map((c) => <li>{c}</li>)}
          </ul>
        </div>
      )}
    </div>
  )}

  <div class="card-actions">
    <a href={`/${slug}`} class="btn-secondary">Read Review</a>
    {affiliate_url && (
      <a
        href={affiliate_url}
        class="btn-primary"
        target="_blank"
        rel="noopener noreferrer nofollow sponsored"
      >
        Visit Site &rarr;
      </a>
    )}
  </div>
</article>

<style>
  .tool-card {
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--radius);
    padding: 1.75rem;
    background-color: var(--color-bg);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .tool-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .card-header {
    margin-bottom: 0.75rem;
  }

  .card-identity {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .card-logo {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-logo img {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    object-fit: contain;
  }

  .logo-fallback {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--color-primary), #6366f1);
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-title {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .card-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .card-title a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .rating-bar {
    width: 80px;
    height: 6px;
    background-color: var(--color-border);
    border-radius: 3px;
    overflow: hidden;
  }

  .rating-bar-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--color-accent), #f97316);
    transition: width 0.3s ease;
  }

  .rating-num {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  .card-desc {
    font-size: 0.93rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .card-summary {
    background-color: var(--color-surface);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.88rem;
    color: var(--color-text);
    font-style: italic;
    line-height: 1.55;
    margin-bottom: 1rem;
    border: 1px solid var(--color-border);
  }

  .summary-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    font-style: normal;
    margin-bottom: 0.2rem;
  }

  .card-pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  @media (max-width: 480px) {
    .card-pros-cons {
      grid-template-columns: 1fr;
    }
  }

  .label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 0.35rem;
  }

  .label-pro { color: var(--color-success); }
  .label-con { color: var(--color-danger); }

  .card-pros-cons ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .card-pros-cons li {
    font-size: 0.85rem;
    padding: 0.2rem 0;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .pros li::before {
    content: '+ ';
    color: var(--color-success);
    font-weight: 700;
  }

  .cons li::before {
    content: '- ';
    color: var(--color-danger);
    font-weight: 700;
  }

  .card-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: #fff;
  }

  .btn-primary:hover {
    background-color: var(--color-primary-hover);
    color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background-color: transparent;
  }

  .btn-secondary:hover {
    background-color: var(--color-surface);
    text-decoration: none;
    border-color: var(--color-text-secondary);
  }
</style>
