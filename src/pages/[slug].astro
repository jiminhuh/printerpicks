---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteData from '../data/site.json';
import tools from '../data/tools.json';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  // Read all .md files from src/content/
  const contentDir = path.join(process.cwd(), 'src', 'content');
  let files: string[] = [];
  try {
    files = fs.readdirSync(contentDir).filter((f: string) => f.endsWith('.md'));
  } catch {
    files = [];
  }

  return files.map((file: string) => {
    const slug = file.replace('.md', '');
    const raw = fs.readFileSync(path.join(contentDir, file), 'utf-8');

    // Parse simple frontmatter
    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
    let frontmatter: Record<string, string> = {};
    let body = raw;

    if (fmMatch) {
      const fmLines = fmMatch[1].split('\n');
      for (const line of fmLines) {
        const idx = line.indexOf(':');
        if (idx > 0) {
          const key = line.slice(0, idx).trim();
          const val = line.slice(idx + 1).trim().replace(/^["']|["']$/g, '');
          frontmatter[key] = val;
        }
      }
      body = fmMatch[2];
    }

    return {
      params: { slug },
      props: { frontmatter, body, slug },
    };
  });
}

const { frontmatter, body, slug } = Astro.props;

// Find matching tool data if it exists
const tool = tools.find((t) => t.slug === slug);

const pageTitle = frontmatter.title || tool?.name || slug;
const pageDescription = frontmatter.description || tool?.description || '';

// Build schema.org Review structured data for tool pages
const schema = tool
  ? {
      "@context": "https://schema.org",
      "@type": "Review",
      "name": `${tool.name} Review`,
      "reviewBody": pageDescription,
      "itemReviewed": {
        "@type": "SoftwareApplication",
        "name": tool.name,
        "applicationCategory": siteData.niche,
      },
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": tool.rating,
        "bestRating": 5,
        "worstRating": 1,
      },
      "author": {
        "@type": "Organization",
        "name": siteData.name,
      },
    }
  : undefined;

const ratingPercent = tool ? (tool.rating / 5) * 100 : 0;
const faviconUrl = tool?.website ? `https://www.google.com/s2/favicons?domain=${tool.website}&sz=64` : '';

// Convert markdown to basic HTML with table support
function markdownToHtml(md: string): string {
  const lines = md.split('\n');
  const outputBlocks: string[] = [];
  let i = 0;

  while (i < lines.length) {
    const line = lines[i];

    // Detect markdown table (lines with | characters)
    if (line.trim().startsWith('|') && line.trim().endsWith('|')) {
      const tableLines: string[] = [];
      while (i < lines.length && lines[i].trim().startsWith('|') && lines[i].trim().endsWith('|')) {
        tableLines.push(lines[i].trim());
        i++;
      }

      if (tableLines.length >= 2) {
        let tableHtml = '<div class="table-responsive"><table>';

        // Header row
        const headerCells = tableLines[0].split('|').filter((c) => c.trim() !== '');
        tableHtml += '<thead><tr>';
        for (const cell of headerCells) {
          tableHtml += `<th>${processInline(cell.trim())}</th>`;
        }
        tableHtml += '</tr></thead>';

        // Skip separator row (the --- row)
        const startRow = tableLines[1].includes('---') ? 2 : 1;

        tableHtml += '<tbody>';
        for (let r = startRow; r < tableLines.length; r++) {
          const cells = tableLines[r].split('|').filter((c) => c.trim() !== '');
          tableHtml += '<tr>';
          for (const cell of cells) {
            tableHtml += `<td>${processInline(cell.trim())}</td>`;
          }
          tableHtml += '</tr>';
        }
        tableHtml += '</tbody></table></div>';
        outputBlocks.push(tableHtml);
      }
      continue;
    }

    // Horizontal rule
    if (/^---+$/.test(line.trim()) || /^\*\*\*+$/.test(line.trim())) {
      outputBlocks.push('<hr>');
      i++;
      continue;
    }

    // Headings
    const h4Match = line.match(/^#### (.+)$/);
    if (h4Match) { outputBlocks.push(`<h4>${processInline(h4Match[1])}</h4>`); i++; continue; }
    const h3Match = line.match(/^### (.+)$/);
    if (h3Match) { outputBlocks.push(`<h3>${processInline(h3Match[1])}</h3>`); i++; continue; }
    const h2Match = line.match(/^## (.+)$/);
    if (h2Match) { outputBlocks.push(`<h2>${processInline(h2Match[1])}</h2>`); i++; continue; }
    const h1Match = line.match(/^# (.+)$/);
    if (h1Match) { outputBlocks.push(`<h1>${processInline(h1Match[1])}</h1>`); i++; continue; }

    // Unordered list
    if (/^[-*] /.test(line.trim())) {
      let listItems = '';
      while (i < lines.length && /^[-*] /.test(lines[i].trim())) {
        listItems += `<li>${processInline(lines[i].trim().replace(/^[-*] /, ''))}</li>`;
        i++;
      }
      outputBlocks.push(`<ul>${listItems}</ul>`);
      continue;
    }

    // Ordered list
    if (/^\d+\. /.test(line.trim())) {
      let listItems = '';
      while (i < lines.length && /^\d+\. /.test(lines[i].trim())) {
        listItems += `<li>${processInline(lines[i].trim().replace(/^\d+\. /, ''))}</li>`;
        i++;
      }
      outputBlocks.push(`<ol>${listItems}</ol>`);
      continue;
    }

    // Blockquote
    if (line.trim().startsWith('> ')) {
      let quoteContent = '';
      while (i < lines.length && lines[i].trim().startsWith('> ')) {
        quoteContent += lines[i].trim().replace(/^> /, '') + ' ';
        i++;
      }
      outputBlocks.push(`<blockquote><p>${processInline(quoteContent.trim())}</p></blockquote>`);
      continue;
    }

    // Empty line
    if (line.trim() === '') {
      i++;
      continue;
    }

    // Paragraph: collect consecutive non-empty non-special lines
    let paraContent = '';
    while (
      i < lines.length &&
      lines[i].trim() !== '' &&
      !lines[i].trim().startsWith('#') &&
      !lines[i].trim().startsWith('|') &&
      !/^[-*] /.test(lines[i].trim()) &&
      !/^\d+\. /.test(lines[i].trim()) &&
      !lines[i].trim().startsWith('> ') &&
      !/^---+$/.test(lines[i].trim()) &&
      !/^\*\*\*+$/.test(lines[i].trim())
    ) {
      paraContent += (paraContent ? ' ' : '') + lines[i].trim();
      i++;
    }
    if (paraContent) {
      outputBlocks.push(`<p>${processInline(paraContent)}</p>`);
    }
  }

  return outputBlocks.join('\n');
}

function processInline(text: string): string {
  return text
    // Bold + italic
    .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
    // Bold
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    // Italic
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    // Inline code
    .replace(/`(.+?)`/g, '<code>$1</code>')
    // Links
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
}

const contentHtml = markdownToHtml(body);
---

<BaseLayout title={`${pageTitle} — ${siteData.name}`} description={pageDescription} schema={schema}>
  <article class="content-page">
    <div class="disclosure">
      This page may contain affiliate links. We may earn a commission at no extra cost to you.
      <a href="/about">Learn more.</a>
    </div>

    <div class="page-title-row">
      {tool && (
        <div class="title-logo">
          {tool.website ? (
            <img
              src={faviconUrl}
              alt={`${tool.name} logo`}
              width="40"
              height="40"
              loading="lazy"
            />
          ) : (
            <div class="logo-fallback">{tool.name.charAt(0)}</div>
          )}
        </div>
      )}
      <h1>{pageTitle}</h1>
    </div>

    {tool && (
      <div class="tool-meta">
        <div class="meta-rating">
          <div class="rating-bar" title={`${tool.rating} out of 5`}>
            <div class="rating-bar-fill" style={`width: ${ratingPercent}%`}></div>
          </div>
          <span class="rating-num">{tool.rating}/5</span>
        </div>
        {tool.affiliate_url && (
          <a
            href={tool.affiliate_url}
            class="btn-cta"
            target="_blank"
            rel="noopener noreferrer nofollow sponsored"
          >
            Try {tool.name} &rarr;
          </a>
        )}
      </div>
    )}

    {tool?.summary && (
      <div class="page-summary">
        {tool.summary}
      </div>
    )}

    <div class="prose" set:html={contentHtml} />

    {tool && (tool.pros?.length > 0 || tool.cons?.length > 0) && (
      <div class="pros-cons-section">
        <h2>Pros and Cons</h2>
        <div class="pros-cons-grid">
          {tool.pros && tool.pros.length > 0 && (
            <div class="pros-box">
              <h3>Pros</h3>
              <ul>
                {tool.pros.map((p) => <li>{p}</li>)}
              </ul>
            </div>
          )}
          {tool.cons && tool.cons.length > 0 && (
            <div class="cons-box">
              <h3>Cons</h3>
              <ul>
                {tool.cons.map((c) => <li>{c}</li>)}
              </ul>
            </div>
          )}
        </div>
      </div>
    )}

    <nav class="page-nav">
      <a href="/">&larr; Back to all tools</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .content-page {
    max-width: 780px;
    margin: 0 auto;
  }

  .disclosure {
    background-color: var(--color-surface);
    border-radius: var(--radius);
    padding: 0.6rem 1rem;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 2rem;
  }

  .disclosure a {
    font-weight: 500;
  }

  .page-title-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.25rem;
  }

  .title-logo {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .title-logo img {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    object-fit: contain;
  }

  .logo-fallback {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--color-primary), #6366f1);
    color: #fff;
    font-weight: 700;
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .page-title-row h1 {
    margin: 0;
  }

  .tool-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .meta-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .rating-bar {
    width: 100px;
    height: 8px;
    background-color: var(--color-border);
    border-radius: 4px;
    overflow: hidden;
  }

  .rating-bar-fill {
    height: 100%;
    border-radius: 4px;
    background: linear-gradient(90deg, var(--color-accent), #f97316);
  }

  .rating-num {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    font-weight: 700;
  }

  .btn-cta {
    display: inline-block;
    padding: 0.55rem 1.3rem;
    background-color: var(--color-primary);
    color: #fff;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-cta:hover {
    background-color: var(--color-primary-hover);
    color: #fff;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .page-summary {
    background-color: var(--color-surface);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1rem 1.25rem;
    font-size: 0.95rem;
    color: var(--color-text);
    font-style: italic;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  /* Prose content styles */
  .prose :global(h2) {
    margin-top: 2.25rem;
  }

  .prose :global(h3) {
    margin-top: 1.75rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1rem;
  }

  .prose :global(a) {
    color: var(--color-primary);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(.table-responsive) {
    overflow-x: auto;
    margin: 1.5rem 0;
    border-radius: var(--radius);
  }

  .prose :global(.table-responsive table) {
    margin: 0;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 0.75rem 1rem;
    margin: 1.25rem 0;
    background-color: var(--color-surface);
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  .prose :global(blockquote p) {
    margin: 0;
  }

  /* Pros/Cons section */
  .pros-cons-section {
    margin-top: 2.5rem;
  }

  .pros-cons-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  @media (max-width: 560px) {
    .pros-cons-grid {
      grid-template-columns: 1fr;
    }
  }

  .pros-box, .cons-box {
    padding: 1.25rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .pros-box {
    background-color: color-mix(in srgb, var(--color-success) 5%, var(--color-bg));
  }

  .cons-box {
    background-color: color-mix(in srgb, var(--color-danger) 5%, var(--color-bg));
  }

  .pros-box h3 { color: var(--color-success); margin-top: 0; font-size: 1rem; }
  .cons-box h3 { color: var(--color-danger); margin-top: 0; font-size: 1rem; }

  .pros-box ul, .cons-box ul {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }

  .pros-box li, .cons-box li {
    font-size: 0.9rem;
    padding: 0.25rem 0;
    color: var(--color-text-secondary);
  }

  .pros-box li::before {
    content: '+ ';
    color: var(--color-success);
    font-weight: 700;
  }

  .cons-box li::before {
    content: '- ';
    color: var(--color-danger);
    font-weight: 700;
  }

  .page-nav {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .page-nav a {
    font-weight: 500;
    font-size: 0.92rem;
  }
</style>
